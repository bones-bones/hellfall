{
  "name": "@hellfall/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "build:prod": "esbuild src/server.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/server.mjs --external:@google-cloud/firestore --external:dotenv --external:@hellfall/scripts",
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "start:prod": "node dist/server.js"
  },
  "dependencies": {
    "@google-cloud/firestore": "^7.1.0",
    "@hellfall/scripts": "workspace:*",
    "@hellfall/shared": "^1.0.0",
    "dotenv": "^16.4.5",
    "jose": "^5.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.8",
    "esbuild": "^0.25.0",
    "tsx": "^4.7.0",
    "typescript": "^5"
  }
}
