# Discord Application: https://discord.com/developers/applications
# Create an app, then OAuth2 → Redirects: add your callback URL (e.g. https://your-auth.example.com/api/discord/callback)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Random secret for signing JWTs (e.g. openssl rand -base64 32)
JWT_SECRET=

# Auth server base URL (defaults to http://localhost:3003 when unset)
# AUTH_SERVER_URL=https://your-auth.example.com

# Where to redirect after login (your React app)
FRONTEND_URL=https://your-username.github.io/hellfall

# Required for /api/tag: guild where user must be a member
# DISCORD_GUILD_ID=

# Optional: Discord snowflake for database contributor role (defaults to constant in source). Tag POST/DELETE require this role.
# DISCORD_TAG_ROLE_ID=

# Required for /api/tag: role ID user must have (set when ready)
# DISCORD_TAG_ROLE_ID=

# Firestore: for local dev, set path to service account JSON
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Firestore: Hellscube card data + overrides + audit + changesets (defaults shown).
# FIRESTORE_DATABASE_ID=hellscube
# FIRESTORE_CARDS_COLLECTION=cards
# FIRESTORE_AUDIT_SUBCOLLECTION=audit
# FIRESTORE_CHANGESETS_COLLECTION=changesets

# Discord role for admin actions (accept/reject changesets). Defaults to 1234.
# DISCORD_ADMIN_ROLE_ID=1234
#
# After `yarn transform-hc`, migrate full DB to Firestore: `yarn migrate-hellscube-db` (see packages/scripts/README.md)

# Optional
# COOKIE_NAME=hellfall_session
# COOKIE_DOMAIN=.skeleton.club
# JWT_ISSUER=hellfall-auth
