{
  "name": "@hellfall/shared",
  "version": "1.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "type": "module",
  "devDependencies": {
    "@types/node": "^20.12.8",
    "typescript": "^5"
  },
  "exports": {
    "./types": {
      "types": "./src/types/index.ts",
      "import": "./src/types/index.ts"
    },
    "./data/*": {
      "types": "./src/data/*",
      "import": "./src/data/*"
    },
    "./services/*": {
      "types": "./src/services/*",
      "import": "./src/services/*"
    },
    "./utils/*": {
      "types": "./src/utils/*",
      "import": "./src/utils/*"
    }
  }
}
