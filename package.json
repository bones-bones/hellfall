{
  "name": "hellfall",
  "version": "0.1.0",
  "private": true,
  "homepage": "/",
  "workspaces": [
    "packages/frontend",
    "packages/backend",
    "packages/shared",
    "packages/server",
    "packages/scripts"
  ],
  "scripts": {
    "start": "yarn workspace @hellfall/frontend start",
    "build": "yarn workspace @hellfall/frontend build",
    "fix": "yarn workspace @hellfall/frontend fix",
    "pretty": "prettier --write .",
    "transform-hc": "yarn workspace @hellfall/backend transform-hc",
    "fetch-oracle-names": "yarn workspace @hellfall/backend fetch-oracle-names",
    "order-lists": "yarn workspace @hellfall/backend order-lists",
    "start:windows": "yarn workspace @hellfall/frontend start:windows",
    "install:all": "yarn install",
    "clean": "rm -rf node_modules packages/*/node_modules",
    "clean:all": "yarn workspaces run clean || true && rm -rf node_modules packages/*/node_modules",
    "reinstall:all": "yarn clean && yarn install",
    "add:frontend": "yarn workspace @hellfall/frontend add",
    "up:frontend": "yarn workspace @hellfall/frontend up",
    "add:backend": "yarn workspace @hellfall/backend add",
    "add:shared": "yarn workspace @hellfall/shared add",
    "add:server": "yarn workspace @hellfall/server add",
    "add:scripts": "yarn workspace @hellfall/scripts add",
    "server:dev": "yarn workspace @hellfall/server dev",
    "server:start": "yarn workspace @hellfall/server start",
    "migrate-hellscube-db": "yarn workspace @hellfall/scripts migrate-hellscube-db",
    "migrate-firestore-tags": "yarn workspace @hellfall/scripts migrate-firestore-tags",
    "export-hellscube-db": "yarn workspace @hellfall/scripts export-hellscube-db"
  },
  "devDependencies": {
    "@types/node": "^20",
    "eslint-plugin-sonarjs": "^4.0.3",
    "prettier": "^2.2.1",
    "typescript": "^5",
    "yarn-deduplicate": "^6.0.2"
  },
  "dependencies": {
    "tsx": "^4.21.0"
  },
  "packageManager": "yarn@4.17.0",
  "resolutions": {
    "@workday/canvas-kit-react@npm:^9.1.42": "patch:@workday/canvas-kit-react@npm%3A9.1.42#~/.yarn/patches/@workday-canvas-kit-react-npm-9.1.42-4f27caa873.patch",
    "@workday/canvas-kit-react@npm:^10.3.63": "patch:@workday/canvas-kit-react@npm%3A10.3.63#~/.yarn/patches/@workday-canvas-kit-react-npm-10.3.63-26eed26648.patch",
    "@workday/canvas-kit-react@npm:^11.2.16": "patch:@workday/canvas-kit-react@npm%3A11.2.16#~/.yarn/patches/@workday-canvas-kit-react-npm-11.2.16-30dac9673f.patch",
    "@workday/canvas-kit-react@npm:^12.6.30": "patch:@workday/canvas-kit-react@npm%3A12.6.30#~/.yarn/patches/@workday-canvas-kit-react-npm-12.6.30-a09c620ad4.patch"
  }
}
