# Discord Application: https://discord.com/developers/applications
# Create an app, then OAuth2 → Redirects: add your callback URL (e.g. https://your-auth.vercel.app/api/discord/callback)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Random secret for signing JWTs (e.g. openssl rand -base64 32)
JWT_SECRET=

# Auth server base URL (Vercel sets VERCEL_URL automatically; override for custom domain)
# AUTH_SERVER_URL=https://your-auth.vercel.app

# Where to redirect after login (your React app)
FRONTEND_URL=https://your-username.github.io/hellfall

# Required for /api/tag: guild where user must be a member
# DISCORD_GUILD_ID=

# Required for /api/tag: role ID user must have (set when ready)
# DISCORD_TAG_ROLE_ID=

# Optional
# COOKIE_NAME=hellfall_session
# JWT_ISSUER=hellfall-auth
